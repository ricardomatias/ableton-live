{
    "compilerOptions": {
        "outDir": "./build",
		"target": "esnext",
		"module": "commonjs",
		"moduleResolution": "node",
		"strict": true,
		"declaration": true,
		"esModuleInterop": true,
		"allowJs": false,
		"noImplicitAny": false,
		"strictPropertyInitialization": false
	},
    "include": [
		"./lib/**/*"
    ],
    "exclude": [
        "/node_modules/"
    ]
}
