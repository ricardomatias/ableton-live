{
	"name": "ableton-live",
	"version": "0.0.1",
	"browser": "build/esm/browser.js",
	"main": "build/cjs/server.js",
	"module": "build/esm/browser.js",
	"types": "build/cjs/index.d.ts",
	"description": "Access Ableton Live via WebSockets",
	"private": "true",
	"scripts": {
		"start": "rollup -c rollup.config.browser.js --watch",
		"build": "npm run build:browser && npm run build:server",
		"build:browser": "rollup -c rollup.config.browser.js",
		"build:server": "rollup -c rollup.config.server.js",
		"check:comments": "leasot -x lib/**/*.ts",
		"lint": "eslint lib",
		"lint:quiet": "eslint lib  --quiet",
		"prepare": "npm run build"
	},
	"files": [
		"build/**/*.js",
		"build/**/*.d.ts"
	],
	"author": {
		"name": "Ricardo Matias",
		"url": "https://github.com/ricardomatias"
	},
	"repository": {
		"type": "git",
		"url": "git://github.com/ricardomatias/ableton-live.git"
	},
	"homepage": "https://github.com/ricardomatias/ableton-live",
	"bugs": {
		"url": "https://github.com/ricardomatias/ableton-live/issues"
	},
	"license": "MIT",
	"keywords": [
		"ableton",
		"live",
		"max",
		"max4live",
		"live-api"
	],
	"dependencies": {
		"@clusterws/cws": "^3.0.0",
		"mitt": "^2.1.0",
		"nanoid": "^3.1.16"
	},
	"devDependencies": {
		"@babel/core": "^7.12.3",
		"@babel/plugin-proposal-class-properties": "^7.12.1",
		"@babel/plugin-proposal-object-rest-spread": "^7.12.1",
		"@babel/plugin-transform-runtime": "^7.12.1",
		"@babel/preset-env": "^7.12.1",
		"@babel/preset-typescript": "^7.12.1",
		"@rollup/plugin-replace": "^2.3.4",
		"@types/node": "^14.14.6",
		"@typescript-eslint/eslint-plugin": "^4.6.1",
		"@typescript-eslint/parser": "^4.6.1",
		"eslint": "^7.13.0",
		"eslint-config-google": "^0.14.0",
		"eslint-plugin-import": "^2.22.1",
		"husky": "^4.3.0",
		"jsdoc": "^3.6.6",
		"jsdoc-memberof-namespace": "^2.2.0",
		"leasot": "^11.4.0",
		"rollup": "^2.33.1",
		"rollup-plugin-babel": "^4.4.0",
		"rollup-plugin-cleanup": "^3.2.1",
		"rollup-plugin-clear": "^2.0.7",
		"rollup-plugin-commonjs": "^10.1.0",
		"rollup-plugin-copy": "^3.3.0",
		"rollup-plugin-delete": "^2.0.0",
		"rollup-plugin-includepaths": "^0.2.4",
		"rollup-plugin-node-builtins": "^2.1.2",
		"rollup-plugin-node-globals": "^1.4.0",
		"rollup-plugin-node-resolve": "^5.2.0",
		"rollup-plugin-progress": "^1.1.2",
		"rollup-plugin-terser": "^7.0.2",
		"rollup-plugin-typescript2": "^0.29.0",
		"tsd-jsdoc": "^2.5.0",
		"ws": "^7.3.1"
	}
}
